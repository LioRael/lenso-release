{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Automerge in-range internal patch updates that only refresh lockfiles",
      "matchPackageNames": ["/^@lenso\\//", "/^lenso(?:-|$)/"],
      "matchUpdateTypes": ["patch"],
      "rangeStrategy": "update-lockfile",
      "groupName": "lenso internal patch dependencies",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Keep manifest or range changes reviewed behind release-intent",
      "matchPackageNames": ["/^@lenso\\//", "/^lenso(?:-|$)/"],
      "matchUpdateTypes": ["minor", "major"],
      "groupName": "lenso internal manifest dependencies",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "prBodyNotes": ["Manifest or dependency-range changes require the release-intent status check."]
    }
  ]
}

