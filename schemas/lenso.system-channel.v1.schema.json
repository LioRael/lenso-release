{
  "$id": "https://lenso.dev/schemas/lenso.system-channel.v1.schema.json",
  "$comment": "Runtime assertion binds a next channel candidateId to the exact candidate-version digest suffix.",
  "oneOf": [
    {
      "type": "object", "additionalProperties": false,
      "required": ["schema", "channel", "systemVersion", "manifestUrl", "manifestSha256", "updatedAt"],
      "properties": { "schema": { "const": "lenso.system-channel.v1" }, "channel": { "const": "stable" }, "systemVersion": { "$ref": "#/$defs/stableSemver" }, "manifestUrl": { "$ref": "#/$defs/httpsUrl" }, "manifestSha256": { "$ref": "#/$defs/sha256" }, "updatedAt": { "$ref": "#/$defs/timestamp" } }
    },
    {
      "type": "object", "additionalProperties": false,
      "required": ["schema", "channel", "systemVersion", "candidateId", "manifestUrl", "manifestSha256", "updatedAt"],
      "properties": { "schema": { "const": "lenso.system-channel.v1" }, "channel": { "const": "next" }, "systemVersion": { "$ref": "#/$defs/candidateSemver" }, "candidateId": { "$ref": "#/$defs/sha256" }, "manifestUrl": { "$ref": "#/$defs/httpsUrl" }, "manifestSha256": { "$ref": "#/$defs/sha256" }, "updatedAt": { "$ref": "#/$defs/timestamp" } }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "stableSemver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
    "candidateSemver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)-next\\.c[0-9a-f]{64}$" },
    "httpsUrl": { "type": "string", "pattern": "^https://[^\\s]+$" },
    "timestamp": { "$ref": "#/$defs/rfc3339" },
    "rfc3339": { "type": "string", "pattern": "^[0-9]{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01])|(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-9]))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?(?:Z|[+-](?:[01][0-9]|2[0-3]):[0-5][0-9])$", "$comment": "Runtime assertion additionally validates leap-year calendar semantics." }
  }
}
