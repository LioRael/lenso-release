{
  "$id": "https://lenso.dev/schemas/lenso.reconciliation-report.v1.schema.json",
  "title": "Lenso reconciliation report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "observedAt", "components", "issues"],
  "properties": {
    "schema": { "const": "lenso.reconciliation-report.v1" },
    "status": { "enum": ["aligned", "drift", "blocked", "observation-failure"] },
    "observedAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$" },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "registry", "tag", "embeddedCatalog", "workerCatalog"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "$ref": "#/$defs/observation" },
          "registry": { "$ref": "#/$defs/observation" },
          "tag": { "$ref": "#/$defs/observation" },
          "embeddedCatalog": { "$ref": "#/$defs/observation" },
          "workerCatalog": { "$ref": "#/$defs/observation" }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "componentId", "detail"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["drift", "blocked", "observation-failure"] },
          "componentId": { "type": "string", "minLength": 1 },
          "detail": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "version", "digest", "publishedAt", "canonicalUrl", "failure"],
      "properties": {
        "state": { "enum": ["present", "missing", "failure", "not-applicable"] },
        "version": { "type": ["string", "null"], "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$" },
        "digest": { "type": ["string", "null"], "pattern": "^(?:sha256:[a-f0-9]{64}|sha512-[A-Za-z0-9+/]{86}==|git:[a-f0-9]{40})$" },
        "publishedAt": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$" },
        "canonicalUrl": { "type": ["string", "null"], "pattern": "^https://" },
        "failure": { "type": ["string", "null"] }
      }
    }
  }
}
