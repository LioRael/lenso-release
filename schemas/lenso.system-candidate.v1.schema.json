{
  "$id": "https://lenso.dev/schemas/lenso.system-candidate.v1.schema.json",
  "$comment": "Runtime assertion recomputes candidateId from canonical candidate bytes with candidateId and systemVersion omitted, binds systemVersion to proposedSystemVersion and candidateId, and enforces uniqueness by repository, package, artifact, and receipt ID.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "candidateId", "systemVersion", "proposedSystemVersion", "bumpReason", "validation", "createdAt", "repositories", "packages", "artifacts", "catalog", "requirements", "receipts", "systemSmokeRunUrls"],
  "properties": {
    "schema": { "const": "lenso.system-candidate.v1" },
    "candidateId": { "$ref": "#/$defs/sha256" },
    "systemVersion": { "$ref": "#/$defs/candidateSemver" },
    "proposedSystemVersion": { "$ref": "#/$defs/stableSemver" },
    "bumpReason": { "$ref": "#/$defs/nonEmpty" },
    "validation": { "type": "object", "additionalProperties": false, "required": ["status", "systemSmokeRunUrls"], "properties": { "status": { "enum": ["pending", "passed", "failed"] }, "systemSmokeRunUrls": { "type": "array", "items": { "$ref": "#/$defs/httpsUrl" } } } },
    "createdAt": { "$ref": "#/$defs/timestamp" },
    "repositories": { "type": "array", "minItems": 1, "uniqueItems": true, "$comment": "Repository names must be unique; assertion validation enforces uniqueness by repository.", "items": { "$ref": "#/$defs/repository" } },
    "packages": { "type": "array", "minItems": 1, "uniqueItems": true, "$comment": "Package IDs must be unique; assertion validation enforces uniqueness by id.", "items": { "$ref": "#/$defs/package" } },
    "artifacts": { "type": "array", "uniqueItems": true, "$comment": "Artifact IDs must be unique; assertion validation enforces uniqueness by id.", "items": { "$ref": "#/$defs/artifact" } },
    "catalog": { "$ref": "#/$defs/catalog" },
    "requirements": { "$ref": "#/$defs/requirements" },
    "receipts": { "type": "array", "minItems": 1, "uniqueItems": true, "$comment": "Receipt IDs must be unique; assertion validation enforces uniqueness by receiptId.", "items": { "$ref": "#/$defs/receiptSummary" } },
    "systemSmokeRunUrls": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/httpsUrl" } }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "semver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$" },
    "stableSemver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
    "candidateSemver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)-next\\.c[0-9a-f]{64}$" },
    "httpsUrl": { "type": "string", "pattern": "^https://[^\\s]+$" },
    "timestamp": { "$ref": "#/$defs/rfc3339" },
    "rfc3339": { "type": "string", "pattern": "^[0-9]{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01])|(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-9]))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?(?:Z|[+-](?:[01][0-9]|2[0-3]):[0-5][0-9])$", "$comment": "Runtime assertion additionally validates leap-year calendar semantics." },
    "repository": { "type": "object", "additionalProperties": false, "required": ["repository", "releaseCommit"], "properties": { "repository": { "$ref": "#/$defs/nonEmpty" }, "releaseCommit": { "$ref": "#/$defs/oid" } } },
    "package": { "type": "object", "additionalProperties": false, "allOf": [{ "if": { "properties": { "id": { "type": "string", "pattern": "^cargo:" } }, "required": ["id"] }, "then": { "properties": { "registryIntegrity": { "type": "string", "pattern": "^[0-9a-f]{64}$" } } } }, { "if": { "properties": { "id": { "type": "string", "pattern": "^npm:" } }, "required": ["id"] }, "then": { "properties": { "registryIntegrity": { "type": "string", "pattern": "^sha512-[A-Za-z0-9+/]{85}[AQgw]==$" } } } }], "required": ["id", "version", "tagUrl", "registryUrl", "registryIntegrity"], "properties": { "id": { "type": "string", "pattern": "^(?:cargo|npm):.+$" }, "version": { "$ref": "#/$defs/semver" }, "tagUrl": { "$ref": "#/$defs/httpsUrl" }, "registryUrl": { "$ref": "#/$defs/httpsUrl" }, "registryIntegrity": { "$ref": "#/$defs/registryIntegrity" } } },
    "artifact": { "type": "object", "additionalProperties": false, "required": ["id", "url", "sha256", "provenanceUrl"], "properties": { "id": { "$ref": "#/$defs/nonEmpty" }, "url": { "$ref": "#/$defs/httpsUrl" }, "sha256": { "$ref": "#/$defs/sha256" }, "provenanceUrl": { "$ref": "#/$defs/httpsUrl" } } },
    "catalog": { "type": "object", "additionalProperties": false, "required": ["url", "sha256"], "properties": { "url": { "$ref": "#/$defs/httpsUrl" }, "sha256": { "$ref": "#/$defs/sha256" } } },
    "requirements": { "type": "object", "additionalProperties": false, "required": ["minimumNode", "minimumRust"], "properties": { "minimumNode": { "$ref": "#/$defs/stableSemver" }, "minimumRust": { "$ref": "#/$defs/stableSemver" } } },
    "registryIntegrity": { "oneOf": [{ "type": "string", "pattern": "^[0-9a-f]{64}$" }, { "type": "string", "pattern": "^sha512-[A-Za-z0-9+/]{85}[AQgw]==$" }] },
    "receiptSummary": { "type": "object", "additionalProperties": false, "required": ["receiptId", "packageId", "version", "sourceCommit", "packedSha256", "tagUrl"], "properties": { "receiptId": { "$ref": "#/$defs/sha256" }, "packageId": { "$ref": "#/$defs/nonEmpty" }, "version": { "$ref": "#/$defs/semver" }, "sourceCommit": { "$ref": "#/$defs/oid" }, "packedSha256": { "$ref": "#/$defs/sha256" }, "tagUrl": { "$ref": "#/$defs/httpsUrl" } } }
  }
}
