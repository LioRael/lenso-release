{
  "name": "@lenso/release-control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24" },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm typecheck && pnpm test",
    "reconcile": "pnpm build && node dist/src/commands/reconcile.js",
    "shadow:deploy": "wrangler deploy --config shadow-gateway/wrangler.jsonc",
    "shadow:typecheck": "tsc --noEmit -p shadow-gateway/tsconfig.json",
    "shadow:types": "wrangler types --config shadow-gateway/wrangler.jsonc shadow-gateway/worker-configuration.d.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && pnpm shadow:typecheck"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "tegami": "1.2.5",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@cloudflare/workers-types": "5.20260711.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "4.110.0"
  }
}
